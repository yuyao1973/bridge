page {
  background: #f6f7f9;
  color: #1f2937;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
}

.container {
  padding: 28rpx;
}

.card {
  margin-bottom: 24rpx;
  padding: 28rpx;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 28rpx rgba(15, 81, 50, 0.08);
}

.title {
  font-size: 42rpx;
  font-weight: 700;
  color: #0f5132;
}

.subtitle {
  margin-top: 12rpx;
  color: #667085;
  font-size: 28rpx;
  line-height: 1.6;
}

.primary-btn {
  margin-top: 20rpx;
  border-radius: 16rpx;
  background: #0f5132;
  color: #ffffff;
}

.secondary-btn {
  margin-top: 20rpx;
  border-radius: 16rpx;
  background: #e7f3ec;
  color: #0f5132;
}

.muted {
  color: #667085;
}
